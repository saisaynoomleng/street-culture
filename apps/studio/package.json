    "sanity-plugin-media": "^4.3.1",
    "styled-components": "^6.1.18"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^6.0.0",
    "@street-culture/utils": "workspace:*",
    "@types/react": "^19",
    "eslint": "^9",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
