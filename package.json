{
  "name": "street-culture",
  "private": "true",
  "version": "1.0.0",
  "description": "Street Culture is an ecommerce webapp that sells street fashion and skateboards around US and Korea",
  "keywords": [
    "nodejs",
    "expressjs",
    "nextjs",
    "ecommerce"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "clean": "turbo clean",
    "test": "pnpm --color -r run vitest"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.5.0",
  "devDependencies": {
    "@manypkg/cli": "^0.25.1",
    "prettier": "^3.8.4",
    "syncpack": "^15.3.1",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  }
}
